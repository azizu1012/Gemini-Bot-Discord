################################################################################
# AZURIS DISCORD BOT - SAMPLE ENV (NO REAL KEYS)
################################################################################

# ===== DISCORD =====
DISCORD_TOKEN=your_discord_bot_token

# ===== GEMINI KEYS (add as many as you have) =====
# Loader supports pattern GEMINI_API_KEY_* (1..N, no hard cap)
GEMINI_API_KEY_1=your_gemini_key_1
GEMINI_API_KEY_2=your_gemini_key_2
GEMINI_API_KEY_3=your_gemini_key_3

# ===== MODELS =====
GEMINI_FLASH_35_MODEL=gemini-3.5-flash
GEMINI_FLASH_30_MODEL=gemini-3-flash-preview
GEMINI_FLASH_LITE_MODEL=gemini-3.1-flash-lite

# Optional: router alias overrides used by message pipeline (not model IDs)
# REASONING_MODEL_ALIAS=gemini-flash-lite-latest
# FINAL_MODEL_ALIAS=gemini-flash-latest
# FALLBACK_MODEL_ALIAS=gemini-flash-lite-latest

# ===== SEARCH SETTINGS (stable production defaults) =====
GOOGLE_SEARCH_STREAMS=1
SEARCH_FALLBACK_PROVIDER_LIMIT=2
# Quality scoring: coverage + evidence + snippet length (no hardcoded trusted domains)
SEARCH_WEB_MODE=grounded
SEARCH_TOP_RESULTS_LIMIT=5
SEARCH_GROUNDED_TOP_LINKS=3
SEARCH_MIN_QUALITY_SOURCES=1
SEARCH_TIME_SENSITIVE_MIN_QUALITY_SOURCES=2
SEARCH_DEEP_READ_TOP_LINKS=2
SEARCH_ENABLE_EXTRA_RETRIEVAL_PASS=true
SEARCH_ALLOW_PARTIAL_ANSWER=true
SEARCH_SEMANTIC_CACHE_ENABLED=true
SEARCH_GENERAL_CACHE_TTL_SEC=21600
SEARCH_TIME_SENSITIVE_CACHE_TTL_SEC=1800
SEARCH_FAILED_QUERY_COOLDOWN_SEC=15
SEARCH_EMPTY_EVIDENCE_CACHE_TTL_SEC=600

# ===== SEARCH API KEYS =====
SERPAPI_API_KEY=your_serpapi_key
TAVILY_API_KEY=your_tavily_key
EXA_API_KEY=your_exa_key

# ===== WEATHER =====
WEATHER_API_KEY=your_weather_key
CITY=Ho Chi Minh City

# ===== ADMIN =====
ADMIN_ID=your_discord_user_id
ADMIN_USER_IDS=your_discord_user_id

# ===== DONATE =====
DONATE_ENCRYPTION_KEY=your_fernet_encryption_key

# ===== PATHS =====
DB_PATH=data/bot_database.db
DB_BACKUP_PATH=data/bot_database.db.backup
MEMORY_PATH=data/short_term_memory.json
FILE_STORAGE_PATH=uploaded_files/
WEATHER_CACHE_PATH=data/weather_cache.json

# ===== STABILITY TUNING =====
REASONING_MAX_API_RETRIES=3
REASONING_MAX_LOOPS=3
FINAL_MAX_API_RETRIES=3
FALLBACK_MAX_API_RETRIES=2

# ===== LIMITS =====
MIN_FREE_SPACE_MB=100
DEFAULT_RATE_LIMIT=5
PREMIUM_RATE_LIMIT=10
DEFAULT_DM_LIMIT=5
PREMIUM_DM_LIMIT=50
