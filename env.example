# Azuris Discord Bot Configuration Template
# Copy this to .env and fill in your real values

# ============================================
# Discord
# ============================================
DISCORD_TOKEN=your_discord_bot_token_here

# ============================================
# Gemini API Keys (rotation)
# ============================================
GEMINI_API_KEY_1=your_gemini_api_key_1
GEMINI_API_KEY_2=your_gemini_api_key_2
GEMINI_API_KEY_3=your_gemini_api_key_3
GEMINI_API_KEY_4=your_gemini_api_key_4
GEMINI_API_KEY_5=your_gemini_api_key_5

# Optional extra keys
# GEMINI_API_KEY_6=your_gemini_api_key_6
# GEMINI_API_KEY_7=your_gemini_api_key_7

# ============================================
# Gemini Router Model Mapping (alias -> provider model id)
# ============================================
GEMINI_FLASH_LATEST_MODEL=your_flash_model_id
GEMINI_FLASH_LITE_LATEST_MODEL=your_flash_lite_model_id

# Per-model quota limits (RPM / TPM / RPD)
# RPD = max requests per day
GEMINI_FLASH_LATEST_RPM=your_flash_latest_rpm
GEMINI_FLASH_LATEST_TPM=your_flash_latest_tpm
GEMINI_FLASH_LATEST_RPD=your_flash_latest_rpd

GEMINI_FLASH_LITE_LATEST_RPM=your_flash_lite_latest_rpm
GEMINI_FLASH_LITE_LATEST_TPM=your_flash_lite_latest_tpm
GEMINI_FLASH_LITE_LATEST_RPD=your_flash_lite_latest_rpd

# ============================================
# Admin / User IDs
# ============================================
ADMIN_ID=your_admin_user_id
ADMIN_USER_IDS=your_admin_user_id_1,your_admin_user_id_2
HABE_USER_ID=your_user_id_here
MIRA_USER_ID=your_user_id_here
ADO_FAT_USER_ID=your_user_id_here
MUC_RIM_USER_ID=your_user_id_here
SUC_VIEN_USER_ID=your_user_id_here
CHUI_USER_ID=your_user_id_here

# ============================================
# Weather
# ============================================
WEATHER_API_KEY=your_weather_api_key
CITY=your_default_city

# ============================================
# Google Search (used by web_search tool)
# New format (recommended)
# ============================================
GOOGLE_SEARCH_ENGINE_ID=your_google_search_engine_id
GOOGLE_SEARCH_API_KEY=your_google_search_api_key

# Optional extra streams for parallel Google search (up to 3 streams)
GOOGLE_SEARCH_ENGINE_ID_1=your_google_search_engine_id_1
GOOGLE_SEARCH_API_KEY_1=your_google_search_api_key_1
GOOGLE_SEARCH_ENGINE_ID_2=your_google_search_engine_id_2
GOOGLE_SEARCH_API_KEY_2=your_google_search_api_key_2

# Legacy CSE format (optional compatibility)
# GOOGLE_CSE_ID=your_google_cse_id
# GOOGLE_CSE_API_KEY=your_google_cse_api_key
# GOOGLE_CSE_ID_1=your_google_cse_id_1
# GOOGLE_CSE_API_KEY_1=your_google_cse_api_key_1
# GOOGLE_CSE_ID_2=your_google_cse_id_2
# GOOGLE_CSE_API_KEY_2=your_google_cse_api_key_2

# ============================================
# Search API Fallbacks
# ============================================
SERPAPI_API_KEY=your_serpapi_api_key
TAVILY_API_KEY=your_tavily_api_key
EXA_API_KEY=your_exa_api_key

# ============================================
# Hugging Face
# ============================================
HF_TOKEN=your_huggingface_token

# ============================================
# Storage / DB paths
# ============================================
DB_PATH=your_db_path
DB_BACKUP_PATH=your_db_backup_path
MEMORY_PATH=your_memory_path
FILE_STORAGE_PATH=your_file_storage_path
WEATHER_CACHE_PATH=your_weather_cache_path

# ============================================
# Limits / Misc
# ============================================
MIN_FREE_SPACE_MB=your_min_free_space_mb
DEFAULT_RATE_LIMIT=your_default_rate_limit
PREMIUM_RATE_LIMIT=your_premium_rate_limit
DEFAULT_DM_LIMIT=your_default_dm_limit
PREMIUM_DM_LIMIT=your_premium_dm_limit

# ============================================
# Optional / Other
# ============================================
ADMIN_TOKEN=your_admin_token
TOKEN=your_legacy_token_if_needed

# Logging
LOG_PATH=your_log_path
LOG_LEVEL=your_log_level
